# ============================================
# WIX CONFIGURATION
# ============================================
# These are auto-generated when you create the app
WIX_CLOUD_PROVIDER="CLOUD_FLARE"
WIX_CLIENT_ID="your_wix_app_id"
WIX_CLIENT_INSTANCE_ID="your_wix_instance_id"
WIX_CLIENT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nyour_wix_public_key_here\n-----END PUBLIC KEY-----"
WIX_CLIENT_SECRET="your_wix_client_secret"

# ============================================
# HUBSPOT CONFIGURATION
# ============================================
HUBSPOT_CLIENT_ID="your_hubspot_client_id"
HUBSPOT_CLIENT_SECRET="your_hubspot_client_secret"
HUBSPOT_REDIRECT_URI="http://localhost:4321/_wix/extensions/hubspot-callback"

# ============================================
# WIX APP CREDENTIALS (aliases for Wix Secrets Manager)
# Same values as WIX_CLIENT_ID / WIX_CLIENT_SECRET
# Wix Secrets Manager blocks names starting with "WIX_CLIENT_"
# ============================================
APP_WIX_CLIENT_ID="your_wix_app_id"
APP_WIX_CLIENT_SECRET="your_wix_client_secret"

# ============================================
# APPLICATION SETTINGS
# ============================================
SYNC_INTERVAL_MINUTES="5"
CONFLICT_RESOLUTION_STRATEGY="last_updated_wins"
DEDUPLICATION_WINDOW_SECONDS="30"
MAX_RETRY_ATTEMPTS="3"
LOG_LEVEL="info"
